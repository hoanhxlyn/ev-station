# Better Auth
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:5173

# Database (SQLite for development)
# On Windows, use absolute path or relative from project root
DATABASE_URL=./dev.db

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Stripe (test mode - use test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_PUBLIC_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
