{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "dictionaries": ["typescript", "node", "project-words"],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./.cspell/project-words.txt",
      "addWords": true
    }
  ],
  "files": ["**/*.{ts,tsx,js,jsx,md}"],
  "ignorePaths": [
    "node_modules",
    "build",
    "dist",
    ".react-router",
    "pnpm-lock.yaml",
    "*.min.js",
    "public"
  ]
}
