    "@fontsource-variable/roboto": "^5.2.10",
    "@mantine/carousel": "^9.0.2",
    "@mantine/charts": "^9.0.2",
    "@mantine/core": "^9.0.2",
    "@mantine/dates": "^9.0.2",
    "@mantine/form": "^9.0.2",
    "@mantine/hooks": "^9.0.2",
    "@mantine/notifications": "^9.0.2",
    "@react-router/node": "7.14.1",
    "@react-router/serve": "7.14.1",
    "@stripe/stripe-js": "^9.2.0",
    "@tabler/icons-react": "^3.41.1",
    "better-auth": "^1.6.4",
    "better-sqlite3": "^12.9.0",
    "consola": "^3.4.2",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "isbot": "^5.1.38",
    "mantine-form-zod-resolver": "^1.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "7.14.1",
    "recharts": "^3.8.1",
    "remix-toast": "^4.0.0",
    "stripe": "^22.0.1",
    "zod": "^4.3.6"
